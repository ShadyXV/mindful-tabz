{
  "manifest_version": 3,
  "name": "Mindful Tabz: Tabs Screen Time Manager",
  "version": "1.0.0",
  "description": "When the allotted moment passes, let the portal close of its own accord.",
  "permissions": ["storage", "tabs", "alarms", "notifications"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "index.html"
  },
  "options_page": "dashboard.html",
  "web_accessible_resources": [
    {
      "resources": ["blocked.html"],
      "matches": ["<all_urls>"]
    }
  ]
}
